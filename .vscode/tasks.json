{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build cpp",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-O2",
                "${file}",
                "${fileDirname}/cpp/*.cpp",
                "-I",
                "${fileDirname}/include",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-larmadillo",
                "-lopenblas"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Task generated by Debugger."
        }
    ]
}