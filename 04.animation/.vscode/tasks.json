{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "main.cpp",
                "cpp/*.cpp",
                "-I",
                "include",
                "-o",
                "main.exe",
                "-larmadillo",
                "-lopenblas",
                ";",
                ".\\main.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}