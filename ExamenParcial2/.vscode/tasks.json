{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
      "args": [
        "-g",
        "main.cpp",
        "cpp/*.cpp",
        "-I",
        "include",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-DARMA_DONT_USE_WRAPPER",
        "-larmadillo",
        "-lopenblas",
        "-o",
        "main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": ".*",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}