{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
      "args": [
        "-g",
        "-O2",
        "main.cpp",
        "cpp/*.cpp",
        "-I",
        "include",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-DARMA_DONT_USE_WRAPPER",
        "-larmadillo",
        "-lopenblas",
        "-o",
        "main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "focus": false,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}